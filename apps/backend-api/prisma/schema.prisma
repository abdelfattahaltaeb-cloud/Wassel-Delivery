generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum DriverStatus {
  AVAILABLE
  OFFLINE
  BLOCKED
}

enum OrderStatus {
  DRAFT
  CREATED
  ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  firstName    String
  lastName     String
  phoneNumber  String?
  status       UserStatus @default(INVITED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userRoles    UserRole[]
  customer     Customer?
  driver       Driver?
}

model Role {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model City {
  id           String        @id @default(cuid())
  name         String
  code         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  zones        Zone[]
  serviceAreas ServiceArea[]
}

model Zone {
  id         String      @id @default(cuid())
  name       String
  code       String      @unique
  cityId     String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  city       City        @relation(fields: [cityId], references: [id])
  orders     Order[]
}

model ServiceArea {
  id         String   @id @default(cuid())
  name       String
  cityId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  city       City     @relation(fields: [cityId], references: [id])
}

model Merchant {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  contactName  String?
  contactPhone String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Customer {
  id        String   @id @default(cuid())
  userId     String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  orders     Order[]
}

model Driver {
  id         String       @id @default(cuid())
  userId      String       @unique
  status      DriverStatus @default(OFFLINE)
  vehicleType String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])
  orders      Order[]
}

model Order {
  id            String      @id @default(cuid())
  referenceCode String      @unique
  status        OrderStatus @default(DRAFT)
  merchantId    String?
  customerId    String?
  driverId      String?
  zoneId        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customer      Customer?   @relation(fields: [customerId], references: [id])
  driver        Driver?     @relation(fields: [driverId], references: [id])
  merchant      Merchant?   @relation(fields: [merchantId], references: [id])
  zone          Zone?       @relation(fields: [zoneId], references: [id])
  settlements   Settlement[]
}

model Settlement {
  id          String   @id @default(cuid())
  orderId      String
  amount       Decimal  @db.Decimal(10, 2)
  currencyCode String   @default("LYD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id])
}
